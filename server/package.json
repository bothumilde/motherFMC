{
  "name": "ironclad-backend",
  "version": "1.0.0",
  "description": "Backend API for Ironclad Configurator with Supabase",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.prod.json",
    "start": "node dist/index.js",
    "start:prod": "node dist/prod-server.js",
    "dev": "tsx watch src/index.ts",
    "dev:prod": "tsx watch src/prod-server.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
